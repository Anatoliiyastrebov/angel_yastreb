# Удобная копия для правки: config/local/secrets.template → сохраните как `.env.local` в корне репозитория.
#
# Проверка продакшена: GET https://angel-yastreb.vercel.app/api/health
# → JSON {"ok":true,"stack":"next",...}. HTML с id="root" и /assets/index-*.js = старый Vite на другом домене.

# Public (browser-safe)
NEXT_PUBLIC_SITE_URL=http://localhost:3001
# На Vercel (прод): NEXT_PUBLIC_SITE_URL=https://angel-yastreb.vercel.app
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to the client bundle
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Публичный https URL этого приложения (лучше совпадает с доменом в Vercel). Используется для ссылок в Telegram.
# Важно: на Vercel проект должен быть собран как Next.js (npm run build / framework Next), без Output Directory = dist от Vite —
# иначе по этому адресу отдаётся один index.html и пути вида /admin/submissions/<id> дают 404 в браузере.
# На Vercel (прод): TELEGRAM_PUBLIC_APP_URL=https://angel-yastreb.vercel.app
TELEGRAM_PUBLIC_APP_URL=
CRON_SECRET=
ADMIN_EMAILS=consultant@example.com

# Optional: private Storage bucket for questionnaire file uploads (create in Supabase)
SUBMISSION_FILES_BUCKET=

# Encryption for legacy OTP “My questionnaires” encrypted rows (existing feature)
ENCRYPTION_KEY=

# Rate limit (hourly per IP) for POST /api/submissions
PUBLIC_SUBMISSION_RATE_LIMIT_PER_HOUR=20

# Bot protection — when set, POST /api/submissions requires token from Turnstile widget
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Optional audit trail table writes (server)
ADMIN_AUDIT_LOG_ENABLED=false

# Retention override for cron (days)
SUBMISSION_RETENTION_DAYS=90
